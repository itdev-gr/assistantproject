# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_HMAC_SECRET=replace-with-strong-secret-32-bytes-hex

# E2E tests (see README §Tests — run scripts/reset-e2e-owner.ts once to sync)
AGA_E2E_OWNER_EMAIL=owner-aegean@itdev.gr
AGA_E2E_OWNER_PASSWORD=replace-with-generated-password

# Sentry (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Mapbox (optional, owner partner addresses)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Stripe (test mode first; run scripts/setup-stripe-products.ts once to create prices)
STRIPE_SECRET_KEY=sk_test_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_PRICE_STANDARD=price_replace
STRIPE_PRICE_FEATURED=price_replace
STRIPE_PRICE_EXCLUSIVE=price_replace
STRIPE_PRICE_HOTEL=price_replace
CRON_SECRET=replace-with-long-random-string

# Future: external chatbot / LLM provider plugged into ResponseProvider
# CHATBOT_API_URL=
# CHATBOT_API_KEY=
