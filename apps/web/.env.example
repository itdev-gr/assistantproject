# Supabase — get these from Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App URL used for absolute links (referral CTAs, magic-link redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required: signs guest session cookies and referral redirect tokens.
# Generate a fresh one for production:  openssl rand -hex 32
SESSION_HMAC_SECRET=please-replace-with-a-32-byte-hex-string

# Public site origin used for absolute SEO URLs (canonical, hreflang, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://assistantproject-web.vercel.app
